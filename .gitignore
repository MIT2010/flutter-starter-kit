# Dart & Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
pubspec.lock

# Environment — JANGAN pernah commit file ini
.env
.env.*
*.dart-define

# IDE
.idea/
.vscode/
.claude/
*.iml

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
lcov.info

# Generated files — di-generate ulang dengan build_runner
*.g.dart
*.freezed.dart
*.gen.dart

# Android
**/android/.gradle/
**/android/local.properties
**/android/captures/
**/android/key.properties
*.jks
*.keystore

# iOS
**/ios/Pods/
**/ios/.symlinks/

# Kecualikan lock file workspace — perlu di-commit untuk konsistensi.
# Catatan: dengan Dart native workspace, hanya ada satu pubspec.lock
# di root (bukan satu per package/app), jadi yang di-exclude di sini
# adalah file root-nya, bukan apps/main/pubspec.lock (yang tidak pernah ada).
!/pubspec.lock

# Generated mock files — di-generate ulang dengan build_runner
**/*.mocks.dart

# Config files — berisi data sensitif, JANGAN commit
config/development.json
config/staging.json
config/production.json

# Obfuscation symbols — JANGAN dihapus atau di-commit ke git biasa
# Simpan di tempat aman terpisah (misal: secrets manager, S3 private bucket)
# Dibutuhkan untuk de-obfuscate crash report production
build/symbols/

# Mason cache/lock — berisi path absolut spesifik mesin yang menjalankan
# `mason get`, tidak portable antar clone. Dijalankan ulang otomatis oleh
# generate_feature.sh / generate_test.sh / create_app.dart sebelum dipakai.
tools/mason/.mason/
tools/mason/mason-lock.json
